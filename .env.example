PORT=4000
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=change_this_to_random_long_secret

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# Required for OTP reset-password APIs in auth-server.js
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# SMTP (Gmail App Password)
# 1) Bật xác minh 2 bước cho Gmail
# 2) Tạo App Password 16 ký tự và dán vào SMTP_PASS (không có khoảng trắng)
# 3) SMTP_FROM dùng cùng email Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password_without_spaces
SMTP_FROM=NikaShop <your_gmail@gmail.com>

# MySQL (for migration away from Supabase)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=nikashop
