    {
      "name": "2. Promotions admin",
      "item": [
        {
          "name": "Create promotion",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json()?.data || {};",
                  "if (data.id) pm.collectionVariables.set('promotionId', data.id);",
                  "if (data.code) pm.collectionVariables.set('promotionCode', data.code);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{promotionCode}}\",\n  \"name\": \"Promotion tu collection admin\",\n  \"discount_percent\": 10,\n  \"min_order\": 500000,\n  \"max_uses_per_user\": 1,\n  \"starts_at\": \"2026-04-10 00:00:00\",\n  \"ends_at\": \"2026-12-31 23:59:59\",\n  \"is_active\": true\n}"
            },
            "url": "{{baseUrl}}/api/promotions/create"
          }
        },
        {
          "name": "Assign promotion specific_user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"promotion_id\": \"{{promotionId}}\",\n  \"mode\": \"specific_user\",\n  \"target_user_id\": \"{{targetUserId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/promotions/assign"
          }
        },
        {
          "name": "Get promotion assignments",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const rows = pm.response.json()?.data || [];",
                  "if (Array.isArray(rows) && rows.length > 0) pm.collectionVariables.set('promotionAssignmentId', rows[0].id || '');"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/promotions/assignments/{{promotionId}}"
          }
        }
      ]
    },
    {
