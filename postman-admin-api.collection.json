  "item": [
    {
      "name": "0. Admin login",
      "item": [
        {
          "name": "Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json() || {};",
                  "const token = body?.data?.access_token || '';",
                  "if (token) pm.collectionVariables.set('accessToken', token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Refresh access token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json() || {};",
                  "const token = body?.data?.access_token || '';",
                  "if (token) pm.collectionVariables.set('accessToken', token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/refresh-token"
          }
        },
        {
          "name": "Session",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/session"
          }
        },
        {
          "name": "Current user (Bearer)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/auth/user"
          }
        }
      ]
    },
    {
      "name": "1. Bootstrap admin variables",
      "item": [
        {
          "name": "Query user by email (set targetUserId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const rows = pm.response.json()?.data || [];",
                  "if (Array.isArray(rows) && rows.length > 0) pm.collectionVariables.set('targetUserId', rows[0].id || '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table\": \"users\",\n  \"select\": \"id,email\",\n  \"filters\": [\n    { \"column\": \"email\", \"op\": \"eq\", \"value\": \"{{userEmail}}\" }\n  ],\n  \"limit\": 1\n}"
            },
            "url": "{{baseUrl}}/api/db/query"
          }
        },
        {
          "name": "Query products (set productId)",
          "event": [
