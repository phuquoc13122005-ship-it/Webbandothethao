  "item": [
    {
      "name": "0 - Public bootstrap",
      "item": [
        {
          "name": "Query Products (public)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json()?.data || [];",
                  "if (Array.isArray(data) && data.length > 0) { pm.collectionVariables.set('productId', data[0].id || ''); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table\": \"products\",\n  \"select\": \"*\",\n  \"order\": { \"column\": \"created_at\", \"ascending\": false },\n  \"limit\": 10\n}"
            },
            "url": "{{baseUrl}}/api/db/query"
          }
        },
        {
          "name": "Query Categories (public)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table\": \"categories\",\n  \"select\": \"*\",\n  \"order\": { \"column\": \"name\", \"ascending\": true },\n  \"limit\": 20\n}"
            },
            "url": "{{baseUrl}}/api/db/query"
          }
        }
      ]
    },
    {
      "name": "1 - User auth flow",
      "item": [
        {
          "name": "Register user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"full_name\": \"User Postman\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login ok', function () { pm.expect(pm.response.code).to.be.oneOf([200]); });",
                  "const body = pm.response.json();",
                  "const id = body?.data?.user?.id || '';",
                  "if (id) pm.collectionVariables.set('targetUserId', id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Session",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/session"
          }
        },
        {
          "name": "Current user",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/user"
          }
        },
        {
          "name": "Change password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"{{userPassword}}\",\n  \"new_password\": \"{{userNewPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/change-password"
          }
        },
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"shouldCreateUser\": false\n}"
            },
            "url": "{{baseUrl}}/api/auth/send-otp"
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"token\": \"{{otpToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/verify-otp"
          }
        },
        {
          "name": "Forgot password request",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json() || {};",
                  "const code = body?.data?.preview?.confirmationCode || '';",
                  "if (code) pm.collectionVariables.set('resetCode', code);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/forgot-password/request"
          }
        },
        {
          "name": "Forgot password verify code",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"code\": \"{{resetCode}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/forgot-password/verify"
          }
        },
        {
          "name": "Forgot password reset",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"code\": \"{{resetCode}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/forgot-password/reset"
          }
        },
        {
          "name": "Logout user",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout"
          }
        }
      ]
    },
