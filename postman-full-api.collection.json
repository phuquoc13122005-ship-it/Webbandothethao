          }
        },
        {
          "name": "Create account (admin only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json() || {};",
                  "const id = body?.data?.account?.id || '';",
                  "if (id) pm.collectionVariables.set('targetUserId', id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{tempAccountEmail}}\",\n  \"full_name\": \"Staff Postman\",\n  \"phone\": \"0909001111\",\n  \"address\": \"HCM\",\n  \"role\": \"staff\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/admin/create-account"
          }
        },
        {
          "name": "Create promotion",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('promotion create ok', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json()?.data || {};",
                  "if (data.id) pm.collectionVariables.set('promotionId', data.id);",
                  "if (data.code) pm.collectionVariables.set('promotionCode', data.code);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{promotionCode}}\",\n  \"name\": \"Promotion Postman 10%\",\n  \"discount_percent\": 10,\n  \"min_order\": 500000,\n  \"max_uses_per_user\": 1,\n  \"starts_at\": \"2026-04-10 00:00:00\",\n  \"ends_at\": \"2026-12-31 23:59:59\",\n  \"is_active\": true\n}"
            },
            "url": "{{baseUrl}}/api/promotions/create"
          }
        },
        {
          "name": "Assign promotion (specific user)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"promotion_id\": \"{{promotionId}}\",\n  \"mode\": \"specific_user\",\n  \"target_user_id\": \"{{targetUserId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/promotions/assign"
          }
        },
        {
          "name": "Get promotion assignments",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const rows = pm.response.json()?.data || [];",
                  "if (Array.isArray(rows) && rows.length > 0) { pm.collectionVariables.set('promotionAssignmentId', rows[0].id || ''); }"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/promotions/assignments/{{promotionId}}"
          }
        },
        {
          "name": "Moderate review (approve)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"review_id\": \"{{reviewId}}\",\n  \"status\": \"approved\"\n}"
            },
            "url": "{{baseUrl}}/api/reviews/moderate"
          }
        },
        {
          "name": "Logout admin",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout"
          }
        }
      ]
