    { "key": "productId", "value": "" },
    { "key": "promotionCode", "value": "KMPOSTMAN10" },
    { "key": "promotionId", "value": "" },
    { "key": "promotionAssignmentId", "value": "" },
    { "key": "targetUserId", "value": "" },
    { "key": "reviewId", "value": "" },
